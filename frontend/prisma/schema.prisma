generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Bill {
  id                 String     @id @default(cuid())
  billNumber         String     @unique
  courseName         String
  studentName        String
  email              String
  phone              String
  customerAddress    String?
  customerCity       String?
  customerState      String?
  customerPostalCode String?
  customerGstin      String?
  placeOfSupply      String?
  courseType         CourseType
  amount             Int        @default(0)
  baseAmount         Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal    @default(0) @db.Decimal(12, 2)
  taxableAmount      Decimal    @default(0) @db.Decimal(12, 2)
  taxRate            Decimal    @default(0) @db.Decimal(5, 2)
  cgstRate           Decimal    @default(0) @db.Decimal(5, 2)
  cgstAmount         Decimal    @default(0) @db.Decimal(12, 2)
  sgstRate           Decimal    @default(0) @db.Decimal(5, 2)
  sgstAmount         Decimal    @default(0) @db.Decimal(12, 2)
  igstRate           Decimal    @default(0) @db.Decimal(5, 2)
  igstAmount         Decimal    @default(0) @db.Decimal(12, 2)
  totalTax           Decimal    @default(0) @db.Decimal(12, 2)
  grandTotal         Decimal    @default(0) @db.Decimal(12, 2)
  priceType          PriceType  @default(TAX_INCLUSIVE)
  sacCode            String?
  invoiceDate        DateTime   @default(now())
  status             BillStatus @default(CREATED)
  emailSent          Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([createdAt])
  @@index([email])
}

model TaxSettings {
  id               String    @id @default("default")
  companyName      String    @default("ADYAPAN EDUTECH PVT. LTD.")
  tradeName        String    @default("ADYAPAN")
  address          String    @default("")
  city             String    @default("")
  state            String    @default("")
  stateCode        String    @default("")
  postalCode       String    @default("")
  gstin            String    @default("")
  pan              String?
  email            String    @default("")
  phone            String    @default("")
  website          String?   @default("www.adyapan.com")
  sacCode          String    @default("999293")
  gstRate          Decimal   @default(18.00) @db.Decimal(5, 2)
  defaultPriceType PriceType @default(TAX_INCLUSIVE)
  isConfigured     Boolean   @default(false)
  updatedAt        DateTime  @updatedAt
}

model InvoiceSequence {
  id            String   @id @default(cuid())
  financialYear String   @unique
  nextVal       Int      @default(1)
  updatedAt     DateTime @updatedAt
}

enum CourseType {
  ONLINE_3500
  ONLINE_5000
  ONLINE_15000
  OFFLINE_45000
}

enum PriceType {
  TAX_INCLUSIVE
  TAX_EXCLUSIVE
}

enum BillStatus {
  CREATED
  SENT
  EMAIL_FAILED
}
